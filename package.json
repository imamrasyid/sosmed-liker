{
  "author": "EyeTracker",
  "name": "sosmed-liker",
  "version": "3.0.0-B20260604",
  "description": "Aplikasi Desktop Otomatisasi Sosmed Liker",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "start": "electron-vite preview",
    "electron:install": "node scripts/install-electron.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "i18next": "^26.3.1",
    "playwright-core": "^1.44.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.8.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.38",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "vite": "^7.3.5"
  },
  "build": {
    "appId": "com.sosmed.liker",
    "productName": "Sosmed Liker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sosmed Liker",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "uninstallDisplayName": "Sosmed Liker"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "."
      }
    ]
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "sqlite3@6.0.1": true,
    "electron-winstaller@5.4.0": true
  }
}
